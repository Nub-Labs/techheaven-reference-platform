# ─────────────────────────────────────────────────────────────────────────────
#  TechHeaven Reference Platform — Environment Configuration
#  Copy this file to .env before running docker compose up
#
#  cp .env.example .env && docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
APP_PORT=80
APP_URL=http://localhost
APP_ENV=local
APP_DEBUG=true

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@techheaven.com
ADMIN_PASSWORD=Admin@12345

# ─── Database ────────────────────────────────────────────────────────────────
DB_DATABASE=techheaven
DB_USERNAME=techheaven
DB_PASSWORD=techheaven_secret
DB_ROOT_PASSWORD=root_secret
MYSQL_EXTERNAL_PORT=3306

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_EXTERNAL_PORT=6379

# ─── Mailpit ─────────────────────────────────────────────────────────────────
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
